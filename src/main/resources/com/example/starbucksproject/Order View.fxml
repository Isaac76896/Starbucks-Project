<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1024.0" style="-fx-background-color: #efefef;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.example.starbucksproject.OrderController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50" spacing="0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 0 20 0 20;">
            <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1E3932;" text="STARBUCKS" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="menuButton" onAction="#menuButtonClick" style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;" text="Menu" />
            <Button fx:id="locationsButton" onAction="#locationsButtonClick" style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;" text="Locations" />
            <Button fx:id="rewardsButton" onAction="#rewardsButtonClick" style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;" text="Rewards" />
            <Button fx:id="giftCardsButton" onAction="#giftCardsButtonClick" style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;" text="Gift Cards" />
            <Button fx:id="cartButton" style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;" text="Cart" />
        </HBox>
    </top>

    <center>
        <VBox spacing="25" style="-fx-padding: 35;">
            <Label style="-fx-font-size: 48; -fx-font-weight: bold;" text="Seasonal" />

            <HBox spacing="10">
                <Button style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14;" text="Hot Drinks" />
                <Button style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14;" text="Iced Drinks" />
                <Button style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14;" text="Other" />
                <Button style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14;" text="All" />
            </HBox>

            <FlowPane hgap="25" vgap="25">
                <VBox prefHeight="260" prefWidth="260" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Dubai Chocolate Matcha" wrapText="true" />
                    <Label style="-fx-font-size: 18;" text="6.25" />
                    <Button onAction="#handleDubaiMatcha" style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14;" text="Add to Cart" />
                </VBox>

                <VBox prefHeight="260" prefWidth="260" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Lavender Matcha" wrapText="true" />
                    <Label style="-fx-font-size: 18;" text="5.95" />
                    <Button onAction="#handleLavenderMatcha" style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14;" text="Add to Cart" />
                </VBox>

                <VBox prefHeight="260" prefWidth="260" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Toasted Coconut Macchiato" wrapText="true" />
                    <Label style="-fx-font-size: 18;" text="6.45" />
                    <Button onAction="#handleToastedCoconutMacchiato" style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14;" text="Add to Cart" />
                </VBox>

                <VBox prefHeight="260" prefWidth="260" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Toasted Coconut Cold Brew" wrapText="true" />
                    <Label style="-fx-font-size: 18;" text="5.75" />
                    <Button onAction="#handleToastedCoconutColdBrew" style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14;" text="Add to Cart" />
                </VBox>
            </FlowPane>
        </VBox>
    </center>

    <right>
        <VBox prefWidth="280" spacing="18" style="-fx-background-color: white; -fx-padding: 25;">
            <Label style="-fx-font-size: 28; -fx-font-weight: bold;" text="Your Order" />
            <Label fx:id="cartStatusLabel" style="-fx-font-size: 18;" text="Items in cart: 0" />
            <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Total" />
            <Label fx:id="totalLabel" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #006241;" text="0.00" />
            <Button onAction="#handlePlaceOrder" style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 16;" text="Place Order" />
        </VBox>
    </right>

    <padding>
        <Insets bottom="0" left="0" right="0" top="0" />
    </padding>
</BorderPane>
