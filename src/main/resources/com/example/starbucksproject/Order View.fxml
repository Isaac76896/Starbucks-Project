<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.starbucksproject.OrderController"
            style="-fx-background-color: #efefef;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" prefHeight="50"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 0 20 0 20;">
            <Label text="STARBUCKS" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1E3932;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="menuButton" text="Menu"
                    onAction="#menuButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="locationsButton" text="Locations"
                    onAction="#locationsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="rewardsButton" text="Rewards"
                    onAction="#rewardsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="giftCardsButton" text="Gift Cards"
                    onAction="#giftCardsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="cartButton" text="Cart"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="25" style="-fx-padding: 35;">
            <Label text="Seasonal"
                   style="-fx-font-size: 48; -fx-font-weight: bold;" />

            <HBox spacing="10">
                <Button text="Hot Drinks"
                        style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14;" />
                <Button text="Iced Drinks"
                        style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14;" />
                <Button text="Other"
                        style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14;" />
                <Button text="All"
                        style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14;" />
            </HBox>

            <FlowPane hgap="25" vgap="25">
                <VBox spacing="12" prefWidth="260" prefHeight="260"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <Label text="Dubai Chocolate Matcha"
                           wrapText="true"
                           style="-fx-font-size: 22; -fx-font-weight: bold;" />
                    <Label text="6.25"
                           style="-fx-font-size: 18;" />
                    <Button text="Add to Cart"
                            onAction="#handleDubaiMatcha"
                            style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14;" />
                </VBox>

                <VBox spacing="12" prefWidth="260" prefHeight="260"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <Label text="Lavender Matcha"
                           wrapText="true"
                           style="-fx-font-size: 22; -fx-font-weight: bold;" />
                    <Label text="5.95"
                           style="-fx-font-size: 18;" />
                    <Button text="Add to Cart"
                            onAction="#handleLavenderMatcha"
                            style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14;" />
                </VBox>

                <VBox spacing="12" prefWidth="260" prefHeight="260"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <Label text="Toasted Coconut Macchiato"
                           wrapText="true"
                           style="-fx-font-size: 22; -fx-font-weight: bold;" />
                    <Label text="6.45"
                           style="-fx-font-size: 18;" />
                    <Button text="Add to Cart"
                            onAction="#handleToastedCoconutMacchiato"
                            style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14;" />
                </VBox>

                <VBox spacing="12" prefWidth="260" prefHeight="260"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <Label text="Toasted Coconut Cold Brew"
                           wrapText="true"
                           style="-fx-font-size: 22; -fx-font-weight: bold;" />
                    <Label text="5.75"
                           style="-fx-font-size: 18;" />
                    <Button text="Add to Cart"
                            onAction="#handleToastedCoconutColdBrew"
                            style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14;" />
                </VBox>
            </FlowPane>
        </VBox>
    </center>

    <right>
        <VBox spacing="18" prefWidth="280"
              style="-fx-background-color: white; -fx-padding: 25;">
            <Label text="Your Order"
                   style="-fx-font-size: 28; -fx-font-weight: bold;" />
            <Label fx:id="cartStatusLabel"
                   text="Items in cart: 0"
                   style="-fx-font-size: 18;" />
            <Label text="Total"
                   style="-fx-font-size: 18; -fx-font-weight: bold;" />
            <Label fx:id="totalLabel"
                   text="0.00"
                   style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #006241;" />
            <Button text="Place Order"
                    onAction="#handlePlaceOrder"
                    style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 16;" />
        </VBox>
    </right>

    <padding>
        <Insets top="0" right="0" bottom="0" left="0" />
    </padding>
</BorderPane>