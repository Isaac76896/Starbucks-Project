<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>


<VBox xmlns:fx="http://javafx.com/fxml" prefWidth="1024" prefHeight="700"
      fx:controller="com.example.starbucksproject.StoreController"
      style="-fx-background-color: #f0f0f0;">

    <!-- Top Nav Bar -->
    <HBox alignment="CENTER_LEFT" spacing="0" prefHeight="50"
          style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 0 20 0 20;">
        <Label text="STARBUCKS" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1E3932;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="menuButton" text="Menu"
                onAction="#menuButtonClick"
                style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
        <Button fx:id="locationsButton" text="Locations"
                onAction="#locationsButtonClick"
                style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"/>
        <Button fx:id="rewardsButton" text="Rewards"
                onAction="#rewardsButtonClick"
                style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
        <Button fx:id="giftCardsButton" text="Gift Cards"
                onAction="#giftCardsButtonClick"
                style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
        <Button fx:id="cartButton" text="Cart"
                onAction="#orderButtonClick"
                style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
    </HBox>

    <!-- Content Area -->
    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <!-- Left Panel: Search + Location Cards -->
        <VBox spacing="12" prefWidth="300" minWidth="280" maxWidth="320"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="25" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Find a store"
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1E3932;"/>

            <!-- Location Search Field -->
            <TextField fx:id="searchField" promptText="Enter your location"
                       style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-border-color: #ccc; -fx-padding: 10 16; -fx-font-size: 13;"/>

            <!-- Use Current Location Button -->
            <Button fx:id="findNearbyButton" text="Use current location" onAction="#onFindNearbyClicked"
                    maxWidth="Infinity"
                    style="-fx-background-color: #00704A; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 20; -fx-cursor: hand;"/>

            <!-- Store Cards List -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: white; -fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="storeCardsBox" spacing="10">
                    <padding>
                        <Insets top="5" right="2" bottom="5" left="2"/>
                    </padding>
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- Right Panel: Map Placeholder -->
        <StackPane HBox.hgrow="ALWAYS"
                   style="-fx-background-color: #e8e8e8;">
            <Label fx:id="mapPlaceholderLabel" text="Location displayed on map"
                   style="-fx-text-fill: #999; -fx-font-size: 16;"
                   StackPane.alignment="CENTER"/>
        </StackPane>

    </HBox>

</VBox>
