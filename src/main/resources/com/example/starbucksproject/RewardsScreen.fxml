<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="700.0" prefWidth="1024.0" style="-fx-background-color: #EBEBEB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.starbucksproject.RewardsController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" prefHeight="50"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 0 20 0 20;">
            <Label text="STARBUCKS" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1E3932;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="menuButton" text="Menu"
                    onAction="#menuButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="locationsButton" text="Locations"
                    onAction="#locationsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="rewardsButton" text="Rewards"
                    onAction="#rewardsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"/>
            <Button fx:id="giftCardsButton" text="Gift Cards"
                    onAction="#giftCardsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="cartButton" text="Cart"
                    onAction="#cartButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #EBEBEB; -fx-background-color: #EBEBEB;">
            <content>
                <VBox spacing="20" style="-fx-padding: 32; -fx-background-color: #EBEBEB;">

                    <Label fx:id="welcomeLabel" text="Welcome, Rain" style="-fx-font-size: 24;"/>

                    <HBox spacing="16">
                        <VBox spacing="12" style="-fx-background-color: #1E3932; -fx-padding: 24; -fx-background-radius: 16;" HBox.hgrow="ALWAYS">
                            <HBox spacing="10" style="-fx-alignment: center-left;">
                                <Label text="★" style="-fx-text-fill: yellow; -fx-font-size: 42;">
                                </Label>
                                <Label fx:id="starBalanceLabel" text="300 stars" style="-fx-text-fill: white; -fx-font-size: 24;">
                                </Label>
                            </HBox>
                            <ProgressBar fx:id="tierProgressBar" maxWidth="Infinity" progress="0.6" style="-fx-accent: #CBA258;" />
                            <HBox>
                                <Label text="Way to go! Keep earning" style="-fx-text-fill: #9EC9A8; -fx-font-size: 12;"/>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="tierGoalLabel" text="500 stars to Gold" style="-fx-text-fill: #9EC9A8; -fx-font-size: 12;"/>
                            </HBox>
                        </VBox>

                        <TextArea fx:id="howitWorksArea" editable="false" prefHeight="160" prefWidth="250" promptText="How it works:" style="-fx-background-color: white; -fx-background-radius: 16;" text="How it works&#10;&#10;Earn 2 Stars per $1 spent when paying with a registered Starbucks Card or the App&#10;&#10;Redeem Stars for rewards - Use your Stars to get free drinks, food, and more&#10;&#10;Level up for bigger rewards- The more Stars you earn, the better the rewards" wrapText="true" HBox.hgrow="NEVER" />
                    </HBox>

                    <Label style="-fx-font-size: 28; -fx-font-weight: bold;" text="Member perks" />

                    <HBox spacing="16">
                        <Button fx:id="freeBirthdayDrinkButton" prefHeight="160" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 16; -fx-alignment: bottom-left; -fx-padding: 16;">
                            <graphic>
                                <VBox spacing="6">
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Free birthday drink" />
                                    <Label maxWidth="150" style="-fx-text-fill: gray; -fx-font-size: 12;" text="Celebrate with a free drink of your choice!" wrapText="true" />
                                </VBox>
                            </graphic>
                        </Button>

                        <Button fx:id="exclusiveOffersButton" prefHeight="160" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 16; -fx-alignment: bottom-left; -fx-padding: 16;">
                            <graphic>
                                <VBox spacing="6">
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Exclusive Offers" />
                                    <Label maxWidth="150" style="-fx-text-fill: gray; -fx-font-size: 12;" text="Get personalized deals and exclusive access to new drops" wrapText="true" />
                                </VBox>
                            </graphic>
                        </Button>

                        <Button fx:id="fastOrderingButton" prefHeight="160" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 16; -fx-alignment: bottom-left; -fx-padding: 16;">
                            <graphic>
                                <VBox spacing="6">
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Fast ordering" />
                                    <Label maxWidth="150" style="-fx-text-fill: gray; -fx-font-size: 12;" text="Skip the line with mobile order and pay" wrapText="true" />
                                </VBox>
                            </graphic>
                        </Button>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <right>
        <VBox fx:id="cartPanel" prefWidth="300" spacing="16"
              style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 0 1;"
              visible="false" managed="false"/>
    </right>

</BorderPane>
