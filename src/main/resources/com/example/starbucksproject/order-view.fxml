<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.starbucksproject.HelloController"
            style="-fx-background-color: #efefef;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: white; -fx-padding: 20;">
            <Label text="Starbucks"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #006241;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Menu" style="-fx-font-size: 18px;" />
            <Label text="Locations" style="-fx-font-size: 18px;" />
            <Label text="Rewards" style="-fx-font-size: 18px;" />
            <Label text="Gift Cards" style="-fx-font-size: 18px;" />
        </HBox>
    </top>

    <center>
        <VBox spacing="25" style="-fx-padding: 35;">
            <Label text="Seasonal"
                   style="-fx-font-size: 48px; -fx-font-weight: bold;" />

            <HBox spacing="10">
                <Button text="Hot Drinks"
                        style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14px;" />
                <Button text="Iced Drinks"
                        style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14px;" />
                <Button text="Other"
                        style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14px;" />
                <Button text="All"
                        style="-fx-background-radius: 20; -fx-background-color: #d9d9d9; -fx-font-size: 14px;" />
            </HBox>

            <FlowPane hgap="25" vgap="25">
                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18; -fx-pref-width: 260; -fx-pref-height: 260;">
                    <Label text="Dubai Chocolate Matcha"
                           wrapText="true"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                    <Label text="\$6.25"
                           style="-fx-font-size: 18px;" />
                    <Button text="Add to Cart"
                            onAction="#handleDubaiMatcha"
                            style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14px;" />
                </VBox>

                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18; -fx-pref-width: 260; -fx-pref-height: 260;">
                    <Label text="Lavender Matcha"
                           wrapText="true"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                    <Label text="\$5.95"
                           style="-fx-font-size: 18px;" />
                    <Button text="Add to Cart"
                            onAction="#handleLavenderMatcha"
                            style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14px;" />
                </VBox>

                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18; -fx-pref-width: 260; -fx-pref-height: 260;">
                    <Label text="Toasted Coconut Macchiato"
                           wrapText="true"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                    <Label text="\$6.45"
                           style="-fx-font-size: 18px;" />
                    <Button text="Add to Cart"
                            onAction="#handleToastedCoconutMacchiato"
                            style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14px;" />
                </VBox>

                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18; -fx-pref-width: 260; -fx-pref-height: 260;">
                    <Label text="Toasted Coconut Cold Brew"
                           wrapText="true"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                    <Label text="\$5.75"
                           style="-fx-font-size: 18px;" />
                    <Button text="Add to Cart"
                            onAction="#handleToastedCoconutColdBrew"
                            style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 14px;" />
                </VBox>
            </FlowPane>
        </VBox>
    </center>

    <right>
        <VBox spacing="18"
              style="-fx-background-color: white; -fx-padding: 25; -fx-pref-width: 280;">
            <Label text="Your Order"
                   style="-fx-font-size: 28px; -fx-font-weight: bold;" />
            <Label fx:id="cartStatusLabel"
                   text="Items in cart: 0"
                   style="-fx-font-size: 18px;" />
            <Label text="Total"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label fx:id="totalLabel"
                   text="\$0.00"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #006241;" />
            <Button text="Place Order"
                    onAction="#handlePlaceOrder"
                    style="-fx-background-color: #006241; -fx-text-fill: white; -fx-background-radius: 16; -fx-font-size: 16px;" />
        </VBox>
    </right>

    <padding>
        <Insets top="0" right="0" bottom="0" left="0" />
    </padding>
</BorderPane>