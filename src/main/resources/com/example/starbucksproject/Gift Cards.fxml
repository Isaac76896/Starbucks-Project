<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.example.starbucksproject.GiftCardController"
            style="-fx-background-color: #f0f0f0;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" prefHeight="50"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 0 20 0 20;">
            <Label text="STARBUCKS" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1E3932;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="menuButton" text="Menu" onAction="#menuButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="locationsButton" text="Locations" onAction="#locationsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="rewardsButton" text="Rewards" onAction="#rewardsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="giftCardsButton" text="Gift Cards"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"/>
            <Button fx:id="cartButton" text="Cart" onAction="#cartButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="20" style="-fx-padding: 32;">

            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <Label text="Gift Cards" style="-fx-font-size: 32; -fx-font-weight: bold;"/>

                <!-- Card designs -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                    <HBox spacing="16">
                        <Button text="Classic Green" onAction="#selectClassicGreen" prefWidth="200" prefHeight="120"
                                style="-fx-background-color: #5B8A6D; -fx-text-fill: white; -fx-font-size: 16; -fx-background-radius: 12;"/>
                        <Button text="Birthday" onAction="#selectBirthday" prefWidth="200" prefHeight="120"
                                style="-fx-background-color: #C9706E; -fx-text-fill: white; -fx-font-size: 16; -fx-background-radius: 12;"/>
                        <Button text="Thank you" onAction="#selectThankYou" prefWidth="200" prefHeight="120"
                                style="-fx-background-color: #D4A85A; -fx-text-fill: white; -fx-font-size: 16; -fx-background-radius: 12;"/>
                    </HBox>
                </VBox>

                <!-- Amount selection -->
                <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                    <Label text="Select Amount:" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    <HBox spacing="12">
                        <Button text="10" onAction="#select10" prefWidth="100"
                                style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        <Button text="25" onAction="#select25" prefWidth="100"
                                style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        <Button text="50" onAction="#select50" prefWidth="100"
                                style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        <Button text="100" onAction="#select100" prefWidth="100"
                                style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    </HBox>
                    <Label text="Enter a different amount:"/>
                    <TextField fx:id="customAmountField" prefWidth="400"/>
                    <Label text="Enter a recipient:"/>
                    <HBox spacing="12">
                        <TextField fx:id="nameField" promptText="name" prefWidth="150"/>
                        <TextField fx:id="emailField" promptText="email address" prefWidth="200"/>
                        <TextField fx:id="messageField" promptText="personal message (optional)" prefWidth="250"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Order Summary -->
            <VBox spacing="16" prefWidth="280" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
                <Label text="Order Summary" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <VBox alignment="CENTER" prefHeight="180" prefWidth="240"
                      style="-fx-background-color: #1E3932; -fx-background-radius: 12;">
                    <Label fx:id="giftCardAmountLabel" text="25" style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </VBox>
                <HBox>
                    <Label text="Gift card"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="amountLabel" text="25"/>
                </HBox>
                <HBox>
                    <Label text="Total:" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalLabel" text="25" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                </HBox>
                <Button text="Purchase gift card" onAction="#purchaseGiftCard"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1E3932; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 14; -fx-padding: 12;"/>
            </VBox>

        </HBox>
    </center>

    <right>
        <VBox fx:id="cartPanel" prefWidth="300" spacing="16"
              style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 0 1;"
              visible="false" managed="false"/>
    </right>

</BorderPane>