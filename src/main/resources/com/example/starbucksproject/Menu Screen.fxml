<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.example.starbucksproject.MenuController"
            prefWidth="1024" prefHeight="700"
            style="-fx-background-color: #f0f0f0;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" prefHeight="50"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 0 20 0 20;">
            <Label text="STARBUCKS" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1E3932;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="menuButton" text="Menu"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true;"/>
            <Button fx:id="locationsButton" text="Locations" onAction="#locationsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="rewardsButton" text="Rewards" onAction="#rewardsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="giftCardsButton" text="Gift Cards" onAction="#giftCardsButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="cartButton" text="Cart" onAction="#cartButtonClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #1E3932; -fx-font-size: 13; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="25" right="40" bottom="25" left="40"/>
            </padding>
            <Label fx:id="categoryHeadingLabel" text="Menu"
                   style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1E3932;"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <HBox fx:id="filterButtonsBox" spacing="8" alignment="CENTER_LEFT"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Search..." prefWidth="200"
                           style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 6 14;"/>
            </HBox>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: #f0f0f0; -fx-background-color: transparent; -fx-border-color: transparent;">
                <FlowPane fx:id="itemCardGrid" hgap="20" vgap="20" alignment="TOP_LEFT">
                    <padding>
                        <Insets top="5" right="5" bottom="5" left="5"/>
                    </padding>
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>

    <right>
        <VBox fx:id="cartPanel" prefWidth="300" spacing="16"
              style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 0 1;"
              visible="false" managed="false">
            <Label text="Your Order" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
            <Label fx:id="cartItemsLabel" text="No items added yet"
                   style="-fx-font-size: 13; -fx-text-fill: gray;" wrapText="true"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Label fx:id="cartTotalLabel" text="Total: $0.00"
                   style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <Button text="Place Order" maxWidth="Infinity"
                    style="-fx-background-color: #1E3932; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 14; -fx-padding: 12; -fx-cursor: hand;"/>
        </VBox>
    </right>

</BorderPane>